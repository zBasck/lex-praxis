# ===================================================================
# Lex-Praxis v2.0.0 — configuracao (copie para .env e ajuste o necessario)
#
# O sistema opera EXCLUSIVAMENTE com:
#   - DJE (Diario de Justica Eletronico) via PJe Comunica (comunica.pje.jus.br)
#   - Monitor de OAB para descoberta automatica de processos
#   - IA local opcional (Ollama, LM Studio, llama.cpp) — 100% gratuita
# DataJud/MNI foi REMOVIDO COMPLETAMENTE.
# ===================================================================

# Chave secreta para sessoes Flask
SECRET_KEY=troque-isto-em-producao-use-uma-chave-aleatoria-de-32-bytes

# Banco de dados (SQLite padrao)
DATABASE_URL=sqlite:///lex_praxis.db

# Usuario admin inicial (login: admin@lexpraxis.local / 1234)
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@lexpraxis.local
ADMIN_PASSWORD=1234

# Agendador
LEX_SCHEDULER=1
HARVEST_INTERVAL_MINUTES=120
DIGEST_HOUR_LOCAL=7

# Monitor de OAB no DJE
OAB_MONITOR_ENABLED=true
OAB_MONITOR_INTERVAL_MINUTES=60
OAB_MONITOR_DAYS_BACK=7

# E-mail (opcional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=seuemail@gmail.com
# SMTP_PASSWORD=sua-senha-de-app
# SMTP_FROM=seuemail@gmail.com
# SMTP_TLS=true

# ===================================================================
# IA Local (gratuita, offline) - opcional
# ===================================================================
# Suporta Ollama (recomendado), LM Studio, llama.cpp ou qualquer
# endpoint OpenAI-compat. Modelos leves recomendados (4-8 GB RAM):
#   ollama pull llama3.1:8b
#   ollama pull qwen2.5:7b
#   ollama pull gemma2:9b
LLM_ENABLED=false
LLM_PROVIDER=ollama           # ollama | lmstudio | openai_compat
LLM_ENDPOINT=http://localhost:11434
LLM_MODEL=llama3.1:8b
LLM_API_KEY=
LLM_TIMEOUT=60

# ===================================================================
# DJe (Diario de Justica Eletronico) - PJe Comunica
# ===================================================================
# Habilita coleta via PJe Comunica (cobre STF, STJ, TRFs, TRTs, ~27 TJs)
# Publico, sem certificado, sem chave de API
DJE_COMUNICA_ENABLED=true
PJE_COMUNICA_URL=https://comunica.pje.jus.br
DJE_DAYS_BACK_DEFAULT=7         # janela retroativa padrao
DJE_MAX_DAYS_BACK=365           # maximo permitido em busca de historico
